datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum MetalType {
  GOLD
  SILVER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  RAZORPAY
  UPI
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  phone        String?
  role         Role          @default(CUSTOMER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  addresses    Address[]
  orders       Order[]
  wishlist     WishlistItem[]
  cart         CartItem[]
  customOrders CustomOrder[]
  testimonials Testimonial[]
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   @default("SHIPPING") // "SHIPPING", "BILLING"
  name       String   // Recipient Name
  phone      String
  street     String
  city       String
  state      String
  postalCode String
  country    String   @default("India")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  metalType MetalType
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id                   String         @id @default(uuid())
  name                 String
  description          String
  weight               Float          // in grams
  purity               String         // "24K", "22K", "18K", "Silver 99.9%"
  metalType            MetalType
  makingChargesPerGram Float
  gstPercent           Float          @default(3.0)
  images               String[]       // Array of URLs
  availability         Boolean        @default(true)
  stockQuantity        Int            @default(1)
  categoryId           String
  category             Category       @relation(fields: [categoryId], references: [id])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  wishlistItems        WishlistItem[]
  cartItems            CartItem[]
  orderItems           OrderItem[]
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Order {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressId       String
  address         Address       @relation(fields: [addressId], references: [id])
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(COD)
  paymentStatus   PaymentStatus @default(PENDING)
  razorpayOrderId String?       @unique
  subtotal        Float
  makingCharges   Float
  gst             Float
  shipping        Float         @default(0.0)
  total           Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           OrderItem[]
  payments        Payment[]
}

model OrderItem {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int
  pricePerUnit  Float
  weightPerUnit Float
  metalRateUsed Float
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  status        PaymentStatus
  amount        Float
  transactionId String        @unique
  createdAt     DateTime      @default(now())
}

model MetalRate {
  id          String    @id @default(uuid())
  metalType   MetalType
  purity      String    // "24K", "22K", "18K", "Silver 99.9%"
  ratePerGram Float
  timestamp   DateTime  @default(now())
}

model CustomOrder {
  id          String    @id @default(uuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  phone       String
  email       String?
  description String
  metalType   MetalType
  designImage String?   // URL or base64 data URL
  status      String    @default("PENDING") // "PENDING", "REVIEWED", "COMPLETED", "CANCELLED"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Testimonial {
  id              String   @id @default(uuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name            String
  location        String
  rating          Int      @default(5)
  review          String
  designPurchased String?
  createdAt       DateTime @default(now())
}
